{
    "name": "mediagone/vue-in-twig-bundle",
    "description": "Vue.js integration for Twig/Symfony without a Node.js toolchain",
    "type": "symfony-bundle",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "symfony/framework-bundle": "^6.1|^7.0",
        "twig/twig": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Mediagone\\VueInTwigBundle\\": "src/"
        }
    },
    "scripts": {
        "demo": "php -S localhost:8000 demo/index.php"
    }
}